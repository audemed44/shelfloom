{
  "name": "shelfloom",
  "private": true,
  "version": "0.1.0",
  "workspaces": ["frontend"],
  "scripts": {
    "dev": "concurrently -n be,fe -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && .venv/Scripts/python -m uvicorn app.main:app --reload --port 8000",
    "dev:frontend": "npm run dev -w frontend",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd backend && .venv/Scripts/python -m pytest --cov=app --cov-fail-under=90",
    "test:frontend": "npm test -w frontend",
    "lint": "concurrently \"npm run lint:backend\" \"npm run lint:frontend\"",
    "lint:backend": "cd backend && .venv/Scripts/python -m ruff check .",
    "lint:frontend": "npm run lint -w frontend",
    "format": "concurrently \"npm run format:backend\" \"npm run format:frontend\"",
    "format:backend": "cd backend && .venv/Scripts/python -m ruff format app tests",
    "format:frontend": "npm run format -w frontend"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
